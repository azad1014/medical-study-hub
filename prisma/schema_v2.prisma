// Medical Study Hub V2 - Database Schema
// Target: 10万用户 / 100万 Flashcard / 1000万 ReviewHistory
//
// Migration Notes:
// 1. ReviewHistory 需要手动执行分区（Prisma 不支持声明式分区）
//    参见: prisma/migrations/partition_review_history.sql
// 2. Subject.path 使用 Materialized Path 用于快速子树查询
// 3. UserDailyStat 由后台定时任务聚合，非实时写入

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 用户与认证 ──────────────────────────────

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  emailVerified DateTime?
  displayName   String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole @default(STUDENT)

  // 学习统计（由后台任务定期同步）
  streakDays         Int      @default(0)
  lastStudyDate      DateTime?
  totalStudyMinutes  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  accounts          Account[]
  sessions          Session[]
  flashcards        Flashcard[]
  reviewHistories   ReviewHistory[]
  questionAttempts  QuestionAttempt[]
  mistakes          Mistake[]
  studySessions     StudySession[]
  aiChats           AITutorChat[]
  collections       FlashcardCollection[]
  userDailyStats    UserDailyStat[]
  userSubjectStats  UserSubjectStat[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([username])
  @@index([deletedAt])
}

enum UserRole {
  STUDENT
  ADMIN
  CONTENT_CREATOR
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

// ── 医学知识库（共享只读数据）────────────────

model Subject {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  icon        String?
  color       String?
  sortOrder   Int      @default(0)

  // Materialized Path: 用于无限深度子树查询
  // 格式: "0001.0002.0003" 表示 3 层深度
  path     String?
  level    Int      @default(0)
  parentId String?
  parent   Subject? @relation("SubjectTree", fields: [parentId], references: [id])
  children Subject[] @relation("SubjectTree")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flashcards Flashcard[]
  questions  Question[]

  @@index([parentId])
  @@index([path])
  @@index([sortOrder])
  @@index([level])
}

// ── 标签系统 ────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String
  userId    String?  // null = 系统预设标签
  color     String?
  createdAt DateTime @default(now())

  flashcardTags FlashcardTag[]
  questionTags  QuestionTag[]

  @@unique([name, userId])
  @@index([userId])
}

// ── 闪卡系统 ────────────────────────────────

model Flashcard {
  id       String @id @default(cuid())
  front    String @db.Text
  back     String @db.Text

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  // 用户私有元数据
  userId     String
  user       User   @relation(fields: [userId], references: [id])

  difficulty Int      @default(3)
  isFavorite Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  source     String?  // "manual" | "ai_generated" | "imported"

  // SRS 状态 (SM-2)
  easeFactor      Float    @default(2.5)
  interval        Int      @default(0)
  repetitions     Int      @default(0)
  nextReviewDate  DateTime @default(now())
  lastReviewDate  DateTime?

  collectionId String?
  collection   FlashcardCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewHistories    ReviewHistory[]
  tags               FlashcardTag[]
  studySessionItems  StudySessionItem[]

  // 核心 SRS 查询：用户今天到期的卡片
  @@index([userId, nextReviewDate, isDeleted])
  // 按科目筛选
  @@index([userId, subjectId, nextReviewDate])
  // 收藏夹
  @@index([userId, isFavorite, updatedAt])
  // 按来源筛选
  @@index([userId, source])
  // 按创建时间（最新卡片）
  @@index([userId, createdAt])
}

model FlashcardCollection {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  cards Flashcard[]

  @@index([userId, isDefault])
  @@index([userId, deletedAt])
}

model FlashcardTag {
  id          String   @id @default(cuid())
  flashcardId String
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([flashcardId, tagId])
  @@index([tagId])
}

// ── 复习记录（核心大表，目标 1000 万行）───────

model ReviewHistory {
  id     String @id @default(cuid())
  cardId String
  userId String

  // SM-2 参数
  rating     Int    // 0=Again, 1=Hard, 2=Good, 3=Easy
  easeFactor Float  // 更新后的 ease factor
  interval   Int    // 分配的间隔（天）
  responseMs Int?   // 用户思考用时（毫秒）

  reviewedAt DateTime @default(now())
  reviewDate DateTime @default(now()) // YYYY-MM-DD，用于分区

  card Flashcard @relation(fields: [cardId], references: [id], onDelete: SetNull)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId, reviewedAt])
  @@index([userId, reviewedAt])
  @@index([userId, reviewDate])
  @@index([reviewDate, rating])
}

// ── 题库 ────────────────────────────────────

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  CASE_ANALYSIS
}

model Question {
  id            String       @id @default(cuid())
  stem          String       @db.Text
  options       Json         // [{ "label": "A", "text": "..." }]
  correctAnswer String[]     // ["A"] or ["A","C"]
  explanation   String       @db.Text
  questionType  QuestionType @default(SINGLE_CHOICE)
  difficulty    Int          @default(3)
  subjectId     String?
  subject       Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  isPublic      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts        QuestionAttempt[]
  mistakes        Mistake[]
  tags            QuestionTag[]
  studySessionItems StudySessionItem[]

  @@index([subjectId, difficulty])
  @@index([questionType, difficulty])
}

model QuestionTag {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([questionId, tagId])
  @@index([tagId])
}

model QuestionAttempt {
  id          String   @id @default(cuid())
  questionId  String
  userId      String
  answer      String[] // 用户选的答案 ["A"]
  isCorrect   Boolean
  timeSpent   Int?     // 秒
  attemptedAt DateTime @default(now())
  attemptDate DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: SetNull)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId, userId, attemptedAt])
  @@index([userId, attemptedAt])
  @@index([userId, attemptDate])
  @@index([isCorrect, questionId])
}

// ── 错题本（轻量聚合）───────────────────────

model Mistake {
  id         String   @id @default(cuid())
  questionId String
  userId     String

  totalWrong    Int      @default(1)
  totalAttempts Int      @default(1)
  correctRate   Float    @default(0)
  lastMistakeAt DateTime @default(now())
  isReviewed    Boolean  @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([userId, lastMistakeAt])
  @@index([userId, correctRate])
  @@index([userId, isReviewed])
}

// ── 学习会话 ────────────────────────────────

enum SessionType {
  FLASHCARD_REVIEW
  QUIZ
  MISTAKE_REVIEW
  FREE_STUDY
}

model StudySession {
  id       String      @id @default(cuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     SessionType
  duration Int         // 秒
  startedAt DateTime   @default(now())
  endedAt  DateTime?

  cardsStudied Int @default(0)
  correctCount Int @default(0)

  items StudySessionItem[]

  @@index([userId, startedAt])
  @@index([userId, type, startedAt])
}

model StudySessionItem {
  id        String   @id @default(cuid())
  sessionId String
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  cardId     String?
  card       Flashcard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  questionId String?
  question   Question?  @relation(fields: [questionId], references: [id], onDelete: SetNull)

  rating    Int?      // SRS rating（仅闪卡）
  isCorrect Boolean?  // （仅题目）
  timeSpent Int?      // 秒

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([cardId])
  @@index([questionId])
}

// ── AI 导师 ─────────────────────────────────

model AITutorChat {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  modelName String   @default("deepseek-chat")
  tokenUsed Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  messages AITutorMessage[]

  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
}

model AITutorMessage {
  id         String   @id @default(cuid())
  chatId     String
  chat       AITutorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role       String   // "user" | "assistant" | "system"
  content    String   @db.Text
  tokenCount Int?
  createdAt  DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([chatId, id])
}

// ── 预聚合统计 ──────────────────────────────

model UserDailyStat {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  statDate DateTime

  cardsReviewed     Int @default(0)
  cardsLearned      Int @default(0)
  questionsAnswered Int @default(0)
  correctCount      Int @default(0)
  studyMinutes      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, statDate])
  @@index([userId, statDate])
}

model UserSubjectStat {
  id        String   @id @default(cuid())
  userId    String
  subjectId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalCards    Int    @default(0)
  masteredCards Int    @default(0)
  learningCards Int    @default(0)
  avgEaseFactor Float  @default(2.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([userId, masteredCards])
}

// ── 审计日志 ────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // "card_created" | "card_reviewed" | ...
  entityType String?  // "Flashcard" | "Question" | ...
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}
